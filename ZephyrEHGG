local autoSpeedEnabled = true
local autoJumpEnabled = true

local function createToggle(name,y,state)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,0,0,24)
    b.Position = UDim2.new(0,0,0,y)
    b.BackgroundColor3 = state and Color3.fromRGB(60,160,100) or Color3.fromRGB(50,50,55)
    b.Text = name..": "..(state and "ON" or "OFF")
    b.Parent = Content
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        if name == "Auto Speed" then
            autoSpeedEnabled = not autoSpeedEnabled
            b.Text = "Auto Speed: "..(autoSpeedEnabled and "ON" or "OFF")
        else
            autoJumpEnabled = not autoJumpEnabled
            b.Text = "Auto Jump: "..(autoJumpEnabled and "ON" or "OFF")
        end
    end)

    return b
end

createToggle("Auto Speed",4,true)
createToggle("Auto Jump",30,true)

local function createBox(label,y,default)
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1,0,0,24)
    box.Position = UDim2.new(0,0,0,y)
    box.BackgroundColor3 = Color3.fromRGB(45,45,50)
    box.Text = label..": "..default
    box.Parent = Content
    Instance.new("UICorner", box)
    return box
end

